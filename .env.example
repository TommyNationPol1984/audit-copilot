# Audit Copilot Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Application Settings
# ============================================
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================
# API Keys (Required)
# ============================================
# Get from: https://makersuite.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=audit_copilot
PGHOST=localhost
PGPORT=5432

# Full database URL (auto-generated from above or set directly)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/audit_copilot

# ============================================
# Redis Configuration
# ============================================
# Redis connection URL
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=redis

# ============================================
# Performance Tuning
# ============================================
# Max concurrent Redis connections
REDIS_MAX_CONNECTIONS=50

# Worker job timeout in seconds
WORKER_TIMEOUT_SECONDS=1800

# Max upload size in MB
MAX_UPLOAD_SIZE_MB=300

# Upload temp directory
UPLOAD_TEMP_DIR=/tmp/audit_copilot_uploads

# ============================================
# Caching Configuration
# ============================================
# Cache TTL in hours
AUDIT_CACHE_TTL_HOURS=168

# ============================================
# Gemini Configuration
# ============================================
# Model to use for analysis
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# ============================================
# Development Settings (local only)
# ============================================
# Enable debug mode (development only)
DEBUG=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# Monitoring & Observability
# ============================================
# Enable Prometheus metrics
METRICS_ENABLED=true

# Enable structured logging
STRUCTURED_LOGGING=true

